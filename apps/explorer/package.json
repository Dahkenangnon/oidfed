		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@vitejs/plugin-react": "^4.4.0",
		"jsdom": "^26.0.0",
		"tailwindcss": "^4.1.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.8.0",
		"vite": "^7.3.2",
		"vitest": "^3.2.0"
	}
