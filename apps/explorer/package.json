		"@uiw/react-json-view": "2.0.0-alpha.41",
		"@xyflow/react": "^12.6.0",
		"cytoscape": "^3.33.2",
		"cytoscape-fcose": "^2.2.0",
		"dagre": "^0.8.5",
		"lucide-react": "^0.511.0",
		"papaparse": "^5.5.0",
		"react": "^19.1.0",
		"react-diff-viewer-continued": "^4.0.0",
		"react-dom": "^19.1.0",
		"react-router": "^7.6.1",
		"shiki": "^3.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.0",
		"@testing-library/react": "^16.0.0",
