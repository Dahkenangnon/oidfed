{
	"name": "@oidfed/monorepo",
	"version": "0.6.0",
	"description": "The complete OpenID Federation 1.0 implementation for JavaScript — runtime-agnostic, spec-compliant, built on Web API standards.",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "turbo run build --filter='./packages/*' --filter='./tools/*'",
		"build:apps": "turbo run build --filter='./apps/*' --filter='./internal/*'",
		"test": "pnpm test:tap && pnpm --filter './tools/*' test",
		"test:apps": "pnpm --filter './apps/*' --filter './internal/*' --if-present test",
		"quick:test": "tsx tests/tap/run-node.ts && pnpm --filter './tools/*' test",
		"test:watch": "vitest",
		"test:tap": "pnpm test:tap:bun && pnpm test:tap:deno && pnpm test:tap:workerd && pnpm test:tap:electron && pnpm test:tap:browser && tsx tests/tap/run-node.ts",
		"test:tap:bun": "bash tests/tap/.bun.sh",
		"test:tap:deno": "bash tests/tap/.deno.sh",
		"test:tap:workerd": "bash tests/tap/.workerd.sh",
		"test:tap:electron": "bash tests/tap/.electron.sh",
		"test:tap:browser": "bash tests/tap/.browsers.sh",
		"test:coverage": "bash scripts/coverage-check.sh",
		"typecheck": "turbo run typecheck --filter='./packages/*' --filter='./tools/*' && tsc -p tests/tap/tsconfig.json --noEmit",
		"typecheck:apps": "turbo run typecheck --filter='./apps/*' --filter='./internal/*'",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "turbo run clean",
		"setup:e2e": "bash scripts/setup-e2e.sh",
		"test:e2e": "NODE_EXTRA_CA_CERTS=$(cat .certs/ca-path.txt)/rootCA.pem vitest run --config tests/e2e/vitest.config.ts",
		"dev:federation": "NODE_EXTRA_CA_CERTS=$(cat .certs/ca-path.txt)/rootCA.pem npx tsx --tsconfig tests/e2e/tsconfig.json scripts/dev-federation.ts",
		"cli": "NODE_TLS_REJECT_UNAUTHORIZED=0 node --no-warnings tools/cli/dist/bin.js",
		"oidfed": "pnpm -s cli",
		"build:publish": "turbo run build --filter='@oidfed/core' --filter='@oidfed/authority' --filter='@oidfed/leaf' --filter='@oidfed/oidc' --filter='@oidfed/cli'",
		"release": "node scripts/release.mjs",
		"test:scripts": "node --test scripts/*.test.mjs",
		"prepare": "husky",
		"commit": "commit",
		"commitlint": "commitlint --edit"
	},
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Dahkenangnon/oidfed.git"
	},
	"author": {
		"name": "Justin Dah-kenangnon",
		"email": "dah.kenangnon@gmail.com"
	},
	"homepage": "https://oidfed.com",
	"bugs": {
		"url": "https://github.com/Dahkenangnon/oidfed/issues"
	},
	"keywords": [
		"openid",
		"federation",
		"oidc",
		"oauth2",
		"trust-chain",
		"entity-configuration",
		"trust-mark"
	],
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=10"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@commitlint/prompt-cli": "^21.0.2",
		"@oidfed/authority": "workspace:*",
		"@oidfed/core": "workspace:*",
		"@oidfed/leaf": "workspace:*",
		"@oidfed/oidc": "workspace:*",
		"@playwright/test": "^1.61.0",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.3",
		"@types/oidc-provider": "^9.5.0",
		"@types/qunit": "^2.19.14",
		"c8": "^11.0.0",
		"electron": "^42.4.1",
		"esbuild": "^0.28.1",
		"express": "^5.2.1",
		"husky": "^9.1.7",
		"jose": "^6.2.3",
		"oidc-provider": "^9.8.5",
		"qunit": "^2.26.0",
		"ts-blank-space": "^0.9.0",
		"tsup": "^8.0.0",
		"tsx": "^4.22.4",
		"turbo": "^2.9.18",
		"typescript": "^6.0.3",
		"undici": "^8.5.0",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"electron",
			"esbuild"
		],
		"overrides": {
			"esbuild": "^0.28.1",
			"qs@<6.15.2": "^6.15.2",
			"postcss@<8.5.10": "^8.5.10",
			"undici@<7.28.0": "^7.28.0",
			"undici@>=8.0.0 <8.2.0": "^8.5.0",
			"js-yaml@<4.2.0": "^4.2.0"
		}
	}
}
